# Banco de dados PostgreSQL (Neon ou outro provider)
DATABASE_URL="postgresql://usuario:senha@host/nomedb?sslmode=require"

# Chave da API do Groq — obtenha GRÁTIS em https://console.groq.com
GROQ_API_KEY="gsk_..."

# Segredo para assinatura dos cookies de sessão (gere com: openssl rand -hex 32)
SESSION_SECRET="troque-por-uma-string-aleatoria-de-pelo-menos-32-caracteres"
