# ─── Banco de dados ───────────────────────────────────────────────────────────
# URL de conexão com o PostgreSQL (Neon ou outro provider)
# Formato Neon: postgresql://usuario:senha@host/nomedb?sslmode=require
DATABASE_URL="postgresql://usuario:senha@host/nomedb?sslmode=require"

# ─── IA ───────────────────────────────────────────────────────────────────────
# Chave da API do Groq — usada para análise dos registros dos alunos e relatórios
# Obtenha GRÁTIS em https://console.groq.com
GROQ_API_KEY="gsk_..."

# ─── Sessão / Auth ────────────────────────────────────────────────────────────
# Segredo para assinar os cookies de sessão (iron-session)
# DEVE ter no mínimo 32 caracteres. Gere com: openssl rand -hex 32
SESSION_SECRET="troque-por-uma-string-aleatoria-de-pelo-menos-32-caracteres"
